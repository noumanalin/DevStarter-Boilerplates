generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOC
  OTHER
}

// -----------------------------
// NEWSLETTER
// -----------------------------
model Newsletter {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  created_at DateTime @default(now())
}

// -----------------------------
// BLOG CATEGORY (cleaned & indexed)
// -----------------------------
model BlogCategory {
  id Int @id @default(autoincrement())

  name        String
  slug        String  @unique
  description String?

  // SEO (keep these, they are essential)
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?

  // Social media – optional; remove if you want to simplify
  ogTitle            String?
  ogDescription      String?
  twitterTitle       String?
  twitterDescription String?

  // Robots directives
  noIndex  Boolean @default(false)
  noFollow Boolean @default(false)

  imageUrl String?
  color    String? // badge colour

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogs Blog[]

  @@index([slug])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([name])
}

// -----------------------------
// BLOG (fixed relation + indexes)
// -----------------------------
model Blog {
  id Int @id @default(autoincrement())

  title   String
  slug    String @unique
  excerpt String
  content String @db.Text // use Text for long content

  featured_img_url     String
  featured_img_alt     String?
  featured_img_caption String?
  secure_url           String?
  cloudinary_public_id String  @unique

  metaTitle       String
  metaDescription String

  is_featured Boolean @default(false)

  faqs Json @default("[]")

  schema_markup Json?
  canonicalUrl  String?

  noIndex  Boolean @default(false)
  noFollow Boolean @default(false)

  ogTitle       String?
  ogDescription String?

  twitterTitle       String?
  twitterDescription String?

  searchableSnippets String[]

  authorName String
  authorBio  String?

  status BlogStatus @default(DRAFT)

  views       Int  @default(0)
  shares      Int  @default(0)
  readingTime Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ----- ADDED RELATION -----
  categoryId Int?
  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Indexes for performance
  @@index([slug]) // unique already, but used in lookups
  @@index([status]) // filter by DRAFT/PUBLISHED
  @@index([createdAt]) // order by date
  @@index([updatedAt])
  @@index([views]) // popular posts
  @@index([is_featured])
  @@index([categoryId]) // foreign key
  @@index([authorName]) // if you filter by author
  @@index([status, createdAt])
}

// -----------------------------
// MEDIA (optional indexes)
// -----------------------------
model Media {
  id Int @id @default(autoincrement())

  url        String
  secure_url String?

  cloudinary_public_id String @unique

  type MediaType

  original_name String?
  mime_type     String?

  width  Int?
  height Int?

  size Int? // bytes

  alt_text String?
  caption  String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([type])
  @@index([created_at])
  @@index([cloudinary_public_id])
}

// --------------------------------------------- Auth System ---------------------------------------------------------
enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  MODERATOR
  SUPPORT
  OTHER
}

enum DeviceType {
  MOBILE
  TABLET
  LAPTOP
  DESKTOP
  OTHER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

model User {
  id String @id @default(cuid())

  name       String?
  email      String     @unique
  password   String
  avatar_url String?
  status     UserStatus @default(ACTIVE)

  role        Role    @default(USER)
  is_verified Boolean @default(false)

  otp          String?
  otp_expires  DateTime?
  otp_purpose  OtpPurpose?
  otp_attempts Int        @default(0)

  last_login_at DateTime?
  deleted_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  logins   LoginHistory[]
  sessions Session[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deleted_at])
}


model LoginHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ipAddress String?

  browser    String?
  os         String?
  deviceType DeviceType?

  screenWidth  Int?
  screenHeight Int?

  userAgent String?

  created_at DateTime @default(now())

  @@index([userId])
  @@index([created_at])
  @@index([userId, created_at])
}

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String      @unique // SHA-256 hash of the token, never the raw value
  ipAddress    String?
  userAgent    String?
  deviceType   DeviceType?

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

